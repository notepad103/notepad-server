# 复制为 .env 后填写真实值（勿将 .env 提交到 Git）
# cp .env.example .env

DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/postgres
BIND_ADDR=0.0.0.0:3000
REDIS_URL=redis://127.0.0.1:6379

SMTP_FROM_EMAIL=your_account@qq.com
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_AUTH_CODE=your_smtp_authorization_code

# JWT（HS256）：务必使用足够长的随机密钥，勿提交真实值
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_bytes
# 访问令牌有效期（秒），默认 604800（7 天）
# JWT_EXP_SECS=604800

# LLM（rig_core::providers::openai::Client::from_env）
OPENAI_API_KEY=your_openai_compatible_api_key
# 例如 DeepSeek: https://api.deepseek.com
OPENAI_BASE_URL=https://api.openai.com/v1
# 业务侧自定义读取的模型名（from_env 不会自动读取这个变量）
OPENAI_MODEL=deepseek-reasoner
